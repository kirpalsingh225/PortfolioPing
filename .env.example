# App
APP_ENV=development
APP_BASE_URL=http://localhost:8000
API_SECRET=dummy-api-secret-change-me
TOKEN_ENCRYPTION_KEY=dummy-fernet-key-change-me

# Redis / ARQ
# Use Upstash TCP/TLS URL for ARQ, not REST URL.
REDIS_URL=rediss://default:dummy-password@dummy-upstash-host.upstash.io:6379

# Supabase
SUPABASE_URL=https://dummy-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=dummy-service-role-key

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=dummy-whatsapp-verify-token
WHATSAPP_APP_SECRET=dummy-whatsapp-app-secret
WHATSAPP_ACCESS_TOKEN=dummy-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=dummy-phone-number-id
WHATSAPP_API_VERSION=v21.0

# Zerodha Kite Connect
BROKER_PROVIDER=zerodha
ZERODHA_API_KEY=dummy-zerodha-api-key
ZERODHA_API_SECRET=dummy-zerodha-api-secret
ZERODHA_REDIRECT_URL=http://localhost:8000/auth/zerodha/callback

# LLM / LangChain
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=dummy-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional local Ollama fallback
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_TEMPERATURE=0.2

# Chat memory
MAX_RAW_MESSAGES=10
SUMMARY_TRIGGER_MESSAGES=18
